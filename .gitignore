# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
SmashSquad/[Ll]ibrary/*
SmashSquad/[Tt]emp/
SmashSquad/[Oo]bj/
SmashSquad/[Bb]uild/
SmashSquad/[Bb]uilds/
SmashSquad/[Ll]ogs/
SmashSquad/[Uu]ser[Ss]ettings/

# Force include scene hierarchy
!/SmashSquad/[Ll]ibrary/LastSceneManagerSetup.txt

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
SmashSquad/[Mm]emoryCaptures/

# Recordings can get excessive in size
SmashSquad/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
SmashSquad/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
SmashSquad/.vs/

# Gradle cache directory
SmashSquad/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
SmashSquad/ExportedObj/
SmashSquad/.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
SmashSquad/sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
SmashSquad/crashlytics-build.properties

# Packed Addressables
SmashSquad/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
SmashSquad/[Aa]ssets/[Ss]treamingAssets/aa.meta
SmashSquad/[Aa]ssets/[Ss]treamingAssets/aa/*
SmashSquad/Assets/Resources/PerformanceTestRunSettings.json.meta
SmashSquad/Assets/Resources/PerformanceTestRunSettings.json
SmashSquad/Assets/Resources/PerformanceTestRunInfo.json.meta
SmashSquad/Assets/Resources/PerformanceTestRunInfo.json

TEMP_ASSETS/*